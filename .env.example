# API keys — required, server-side only (never exposed to client)
OPENAI_API_KEY=sk-proj-...
ANTHROPIC_API_KEY=sk-ant-...

# Tier models (any OpenAI or Anthropic model)
# Provider is inferred from the model name: claude-* → Anthropic, otherwise → OpenAI
TIER1_MODEL=gpt-5.4-mini
TIER2_MODEL=claude-opus-4-6
